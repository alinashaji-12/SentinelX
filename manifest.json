{
  "manifest_version": 3,
  "name": "Sentinel Browse",
  "version": "2.0.0",
  "description": "Real-time URL threat detection and blocking. Protects against phishing, malware, and typosquatting.",

  "permissions": [
    "storage",
    "tabs",
    "webNavigation",
    "webRequest",
    "declarativeNetRequest",
    "declarativeNetRequestFeedback"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Sentinel Browse"
  },

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "sentinel_static_rules",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },

  "web_accessible_resources": [
    {
      "resources": [
        "warning.html",
        "warning.js",
        "assets/*"
      ],
      "matches": ["<all_urls>"]
    }
  ],

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["behaviorMonitor.js"],
      "run_at": "document_start",
      "all_frames": false
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}